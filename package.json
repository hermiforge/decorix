{
  "name": "decorix",
  "version": "0.3.0",
  "description": "Framework-neutral TypeScript model metadata with adapters for validation, forms, and documentation.",
  "license": "LGPL-3.0-or-later",
  "author": "Hermiforge",
  "homepage": "https://github.com/hermiforge/decorix#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hermiforge/decorix.git"
  },
  "bugs": "https://github.com/hermiforge/decorix/issues",
  "engines": {
    "node": ">=22"
  },
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "packages/*",
    "packages/adapters/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "examples:typecheck": "tsc --noEmit -p examples/tsconfig.json",
    "examples:run": "node examples/run-all.mjs",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish --no-git-tag",
    "tag:release": "node scripts/tag-release.mjs"
  },
  "devDependencies": {
    "@angular/compiler": "22.0.3",
    "@changesets/cli": "2.31.0",
    "@types/node": "^22",
    "eslint": "^9",
    "eslint-plugin-sonarjs": "^3",
    "globals": "^17.7.0",
    "rimraf": "6.1.3",
    "tsdown": "^0.22.3",
    "tsx": "^4.20.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8",
    "vitest": "3.2.6",
    "zod": "4.4.3"
  }
}
