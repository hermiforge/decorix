{
  "name": "decorix",
  "version": "0.1.0",
  "description": "Framework-neutral TypeScript model metadata with adapters for validation, forms, and documentation.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "examples:typecheck": "tsc --noEmit -p examples/tsconfig.json",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.6",
    "zod": "4.4.3"
  }
}
