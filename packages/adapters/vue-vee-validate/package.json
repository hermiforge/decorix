{
  "name": "@decorix/vue-vee-validate",
  "version": "0.1.0",
  "description": "VeeValidate adapter for Decorix metadata.",
  "license": "LGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config ../../../tsup.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../../vitest.config.ts --dir . --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@decorix/core": "workspace:0.1.0"
  },
  "peerDependencies": {
    "vee-validate": "4.15.1",
    "vue": "3.5.39"
  },
  "peerDependenciesMeta": {
    "vee-validate": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
