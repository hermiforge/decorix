{
  "name": "@hermiforge-decorix/react-hook-form",
  "version": "0.3.2",
  "description": "React Hook Form adapter for Decorix metadata.",
  "license": "LGPL-3.0-or-later",
  "author": "Hermiforge",
  "homepage": "https://github.com/hermiforge/decorix#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hermiforge/decorix.git",
    "directory": "packages/adapters/react-hook-form"
  },
  "bugs": "https://github.com/hermiforge/decorix/issues",
  "keywords": [
    "decorix",
    "react",
    "react-hook-form",
    "validation",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../../tsdown.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../../vitest.config.ts --dir . --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hermiforge-decorix/core": "workspace:0.3.2"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-hook-form": "^7.80.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    }
  }
}
