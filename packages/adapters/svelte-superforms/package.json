{
  "name": "@hermiforge-decorix/svelte-superforms",
  "version": "0.2.1",
  "description": "Superforms (sveltekit-superforms) validation adapter for Decorix metadata.",
  "license": "LGPL-3.0-or-later",
  "author": "Hermiforge",
  "homepage": "https://github.com/hermiforge/decorix#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hermiforge/decorix.git",
    "directory": "packages/adapters/svelte-superforms"
  },
  "bugs": "https://github.com/hermiforge/decorix/issues",
  "keywords": [
    "decorix",
    "svelte",
    "sveltekit",
    "superforms",
    "validation",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../../tsdown.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../../vitest.config.ts --dir . --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hermiforge-decorix/core": "workspace:0.2.1",
    "@hermiforge-decorix/json-schema": "workspace:0.2.1"
  },
  "devDependencies": {
    "@sveltejs/kit": "2.69.1",
    "svelte": "5.56.4",
    "sveltekit-superforms": "2.30.2"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^1.0.0 || ^2.0.0",
    "svelte": "^3.0.0 || ^4.0.0 || ^5.0.0",
    "sveltekit-superforms": "^2.30.0"
  },
  "peerDependenciesMeta": {
    "@sveltejs/kit": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "sveltekit-superforms": {
      "optional": true
    }
  }
}
