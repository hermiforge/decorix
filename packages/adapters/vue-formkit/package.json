{
  "name": "@hermiforge-decorix/vue-formkit",
  "version": "0.3.2",
  "description": "FormKit adapter for Decorix metadata.",
  "license": "LGPL-3.0-or-later",
  "author": "Hermiforge",
  "homepage": "https://github.com/hermiforge/decorix#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hermiforge/decorix.git",
    "directory": "packages/adapters/vue-formkit"
  },
  "bugs": "https://github.com/hermiforge/decorix/issues",
  "keywords": [
    "decorix",
    "vue",
    "formkit",
    "validation",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../../tsdown.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../../vitest.config.ts --dir . --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hermiforge-decorix/core": "workspace:0.3.2"
  },
  "devDependencies": {
    "@formkit/vue": "2.1.0",
    "vue": "3.5.39"
  },
  "peerDependencies": {
    "@formkit/vue": "^2.1.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@formkit/vue": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
