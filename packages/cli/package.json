{
  "name": "@decorix/cli",
  "version": "0.1.0",
  "description": "Command-line interface for generating artifacts from Decorix models.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "decorix": "./bin/decorix.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup --config ../../tsup.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --dir . --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@decorix/core": "workspace:0.1.0",
    "@decorix/json-schema": "workspace:0.1.0",
    "cac": "^7.0.0",
    "tsx": "^4.20.0"
  },
  "devDependencies": {
    "@types/node": "^22"
  }
}
