{
  "name": "@decorix/react-hook-form",
  "version": "0.1.0",
  "description": "React Hook Form adapter for Decorix metadata.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config ../../tsup.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --dir . --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@decorix/core": "workspace:0.1.0"
  },
  "peerDependencies": {
    "react": "19.2.7",
    "react-hook-form": "7.80.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    }
  }
}
