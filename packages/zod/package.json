{
  "name": "@decorix/zod",
  "version": "0.1.0",
  "description": "Zod adapter for Decorix metadata.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config ../../tsup.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --dir . --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@decorix/core": "workspace:0.1.0"
  },
  "peerDependencies": {
    "zod": "4.4.3"
  }
}
